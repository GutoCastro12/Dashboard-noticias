<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#101319; --surface:#171c26; --surface2:#1d2432; --border:#242e40;
  --text:#e8edf5; --muted:#8b96a8; --accent:#5b8def;
  --critico:#ff3b5c; --alto:#ff8a3d; --medio:#f5c518; --info:#3ddc97;
  --radius:10px;
  --display:'Space Grotesk',system-ui,sans-serif;
  --body:'Inter',system-ui,sans-serif;
  --mono:'IBM Plex Mono',ui-monospace,monospace;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:var(--body);font-size:14px;line-height:1.55;
  background-image:radial-gradient(1200px 400px at 70% -10%, rgba(91,141,239,.07), transparent 60%);}
a{color:inherit;text-decoration:none}
.wrap{max-width:1180px;margin:0 auto;padding:28px 20px 60px}

/* ── header ─────────────────────────────── */
header{display:flex;flex-wrap:wrap;justify-content:space-between;align-items:flex-end;gap:16px;
  padding-bottom:20px;border-bottom:1px solid var(--border);margin-bottom:26px}
.eyebrow{font-family:var(--mono);font-size:11px;letter-spacing:.14em;color:var(--accent);text-transform:uppercase;margin-bottom:8px}
h1{font-family:var(--display);font-size:clamp(24px,3.4vw,34px);font-weight:700;letter-spacing:-.01em}
.gen-meta{font-family:var(--mono);font-size:11px;color:var(--muted);text-align:right}
.demo-badge{display:inline-block;margin-top:6px;padding:3px 9px;border:1px dashed var(--medio);
  border-radius:99px;color:var(--medio);font-family:var(--mono);font-size:10px;letter-spacing:.1em}
.totals{display:flex;gap:10px;margin-top:12px;flex-wrap:wrap}
.total-chip{display:flex;align-items:center;gap:8px;background:var(--surface);border:1px solid var(--border);
  border-radius:99px;padding:5px 14px 5px 10px;font-size:12px;color:var(--muted)}
.total-chip b{font-family:var(--mono);color:var(--text);font-size:13px}
.dot{width:8px;height:8px;border-radius:50%}
.dot.critico{background:var(--critico)} .dot.alto{background:var(--alto)} .dot.medio{background:var(--medio)} .dot.info{background:var(--info)}

/* ── radar de emissores (assinatura) ─────── */
section{margin-bottom:34px}
.sec-head{display:flex;align-items:baseline;gap:12px;margin-bottom:14px}
.sec-title{font-family:var(--display);font-size:17px;font-weight:700;letter-spacing:.01em}
.sec-sub{font-size:12px;color:var(--muted)}
.radar{display:flex;flex-direction:column;gap:8px}
.radar-row{display:grid;grid-template-columns:34px 170px 1fr 84px;gap:14px;align-items:center;
  background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
  padding:13px 16px;transition:border-color .15s}
.radar-row:hover{border-color:#31405c}
.radar-row.attention{border-color:rgba(255,59,92,.55);background:linear-gradient(90deg, rgba(255,59,92,.08), var(--surface) 45%)}
.rank{font-family:var(--mono);font-size:13px;color:var(--muted)}
.radar-company{font-weight:600;font-size:14px}
.attn-tag{display:inline-block;margin-top:3px;font-family:var(--mono);font-size:9.5px;letter-spacing:.12em;
  color:var(--critico);border:1px solid rgba(255,59,92,.5);border-radius:4px;padding:2px 6px;animation:pulse 2.2s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.45}}
@media (prefers-reduced-motion: reduce){.attn-tag{animation:none}}
.radar-mid{min-width:0}
.bar-track{height:7px;background:var(--surface2);border-radius:99px;overflow:hidden;margin-bottom:8px}
.bar-fill{height:100%;border-radius:99px}
.bar-fill.critico{background:linear-gradient(90deg,#7a1d2c,var(--critico))}
.bar-fill.alto{background:linear-gradient(90deg,#7a4014,var(--alto))}
.bar-fill.medio{background:linear-gradient(90deg,#6e5a0a,var(--medio))}
.chips{display:flex;flex-wrap:wrap;gap:6px}
.chip{font-family:var(--mono);font-size:10px;padding:2px 8px;border-radius:5px;border:1px solid var(--border);color:var(--muted);background:var(--surface2)}
.chip.critico{color:var(--critico);border-color:rgba(255,59,92,.4)}
.chip.alto{color:var(--alto);border-color:rgba(255,138,61,.4)}
.chip.medio{color:var(--medio);border-color:rgba(245,197,24,.4)}
.chip.info{color:var(--info);border-color:rgba(61,220,151,.4)}
.chip .x{opacity:.65}
.radar-score{text-align:right}
.radar-score b{font-family:var(--mono);font-size:22px;font-weight:600;display:block;line-height:1.1}
.radar-score span{font-family:var(--mono);font-size:10px;color:var(--muted)}
.empty{background:var(--surface);border:1px dashed var(--border);border-radius:var(--radius);
  padding:26px;text-align:center;color:var(--muted);font-size:13px}
.tier-badge{font-family:var(--mono);font-size:9.5px;color:var(--muted);border:1px solid var(--border);
  border-radius:4px;padding:1px 5px;vertical-align:2px;margin-left:6px}

/* ── evolução por emissor ────────────────── */
.evo-summary{display:flex;gap:14px;margin-bottom:12px;font-family:var(--mono);font-size:11px}
.evo-count{padding:3px 10px;border-radius:99px;border:1px solid var(--border);color:var(--muted)}
.evo-count.critico{color:var(--critico);border-color:rgba(255,59,92,.4)}
.evo-count.alto{color:var(--alto);border-color:rgba(255,138,61,.4)}
.evo-count.medio{color:var(--medio);border-color:rgba(245,197,24,.4)}
.evo{display:flex;flex-direction:column;gap:8px}
.evo-row{display:grid;grid-template-columns:190px 1fr 84px;gap:18px;align-items:center;
  background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px}
.evo-row:hover{border-color:#31405c}
.evo-row.status-critico{border-left:3px solid var(--critico)}
.evo-row.status-atencao{border-left:3px solid var(--alto)}
.evo-row.status-monitorar{border-left:3px solid var(--medio)}
.evo-company{font-weight:600;font-size:14px}
.evo-dates{font-family:var(--mono);font-size:10px;color:var(--muted);margin:3px 0 7px}
.status-badge{display:inline-block;font-family:var(--mono);font-size:9.5px;letter-spacing:.1em;
  text-transform:uppercase;border-radius:4px;padding:3px 8px;border:1px solid}
.status-badge.critico{color:var(--critico);border-color:rgba(255,59,92,.5);background:rgba(255,59,92,.08)}
.status-badge.alto{color:var(--alto);border-color:rgba(255,138,61,.5);background:rgba(255,138,61,.08)}
.status-badge.medio{color:var(--medio);border-color:rgba(245,197,24,.5);background:rgba(245,197,24,.08)}
.evo-mid{min-width:0}
.evo-track{position:relative;height:26px;margin-bottom:9px}
.evo-track-line{position:absolute;top:50%;left:0;right:0;height:2px;background:var(--surface2);border-radius:2px}
.evo-dot{position:absolute;top:50%;width:12px;height:12px;border-radius:50%;
  transform:translate(-50%,-50%);border:2px solid var(--bg);transition:transform .1s;z-index:1}
.evo-dot:hover{transform:translate(-50%,-50%) scale(1.5);z-index:2}
.evo-dot.critico{background:var(--critico)} .evo-dot.alto{background:var(--alto)} .evo-dot.medio{background:var(--medio)} .evo-dot.info{background:var(--info)}
.evo-spark{display:block;margin-top:2px}
.evo-spark polyline{fill:none;stroke-width:2;stroke-linejoin:round;stroke-linecap:round}
.evo-spark.critico polyline{stroke:var(--critico)} .evo-spark.atencao polyline{stroke:var(--alto)} .evo-spark.monitorar polyline{stroke:var(--medio)}
.spark-label{font-family:var(--mono);font-size:9px;color:var(--muted)}
.evo-legend{display:flex;justify-content:space-between;margin-top:10px;
  font-family:var(--mono);font-size:10px;color:var(--muted)}

/* ── filtros ─────────────────────────────── */
.filters{display:flex;flex-wrap:wrap;gap:10px;align-items:center;margin-bottom:18px}
.search{flex:1;min-width:220px;background:var(--surface);border:1px solid var(--border);color:var(--text);
  border-radius:8px;padding:9px 14px;font-size:13px;font-family:var(--body);outline:none}
.search:focus{border-color:var(--accent)}
.sev-toggle{cursor:pointer;user-select:none;display:flex;align-items:center;gap:7px;background:var(--surface);
  border:1px solid var(--border);border-radius:8px;padding:8px 14px;font-size:12.5px;color:var(--muted)}
.sev-toggle.active{color:var(--text);border-color:#3a4b66}
.sev-toggle.active.critico{border-color:rgba(255,59,92,.6)}
.sev-toggle.active.alto{border-color:rgba(255,138,61,.6)}
.sev-toggle.active.medio{border-color:rgba(245,197,24,.6)}
.sev-toggle.active.info{border-color:rgba(61,220,151,.6)}
.sev-toggle:not(.active){opacity:.45}
select{background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:8px;
  padding:9px 12px;font-size:12.5px;font-family:var(--body);outline:none}

/* ── feed ────────────────────────────────── */
.sev-group{margin-bottom:26px}
.sev-group-head{display:flex;align-items:baseline;gap:10px;margin-bottom:10px}
.sev-group-title{font-family:var(--display);font-size:15px;font-weight:700}
.sev-group-count{font-family:var(--mono);font-size:11px;color:var(--muted)}
.cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:10px}
.card{position:relative;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
  padding:14px 16px 14px 18px;display:flex;flex-direction:column;gap:8px;transition:border-color .15s}
.card::before{content:"";position:absolute;left:0;top:10px;bottom:10px;width:3px;border-radius:3px}
.card.critico::before{background:var(--critico)}
.card.alto::before{background:var(--alto)}
.card.medio::before{background:var(--medio)}
.card.info::before{background:var(--info)}
.card:hover{border-color:#31405c}
.card-top{display:flex;justify-content:space-between;gap:10px;align-items:flex-start}
.card-title{font-size:13.5px;font-weight:600;line-height:1.4}
.card-title a:hover{color:var(--accent)}
.card-score{font-family:var(--mono);font-size:14px;font-weight:600;white-space:nowrap}
.card-score.critico{color:var(--critico)} .card-score.alto{color:var(--alto)} .card-score.medio{color:var(--medio)} .card-score.info{color:var(--info)}
.card-summary{font-size:12px;color:var(--muted);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.card-meta{display:flex;justify-content:space-between;gap:8px;font-family:var(--mono);font-size:10.5px;color:var(--muted)}
.company-tags{display:flex;gap:6px;flex-wrap:wrap}
.company-tag{font-size:10.5px;font-weight:600;background:var(--surface2);border:1px solid var(--border);
  border-radius:5px;padding:2px 8px;color:var(--accent)}
footer{margin-top:40px;padding-top:16px;border-top:1px solid var(--border);
  font-family:var(--mono);font-size:11px;color:var(--muted);display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px}
@media (max-width:720px){
  .radar-row{grid-template-columns:26px 1fr 70px;grid-template-areas:"rank company score" "mid mid mid"}
  .rank{grid-area:rank}.radar-company-wrap{grid-area:company}.radar-mid{grid-area:mid}.radar-score{grid-area:score}
  .evo-row{grid-template-columns:1fr 70px;grid-template-areas:"left score" "mid mid"}
  .evo-left{grid-area:left}.evo-mid{grid-area:mid}.evo-row .radar-score{grid-area:score}
  .gen-meta{text-align:left}
}
</style>
</head>
<body>
<div class="wrap">

<header>
  <div>
    <div class="eyebrow">Monitor de risco · janela de {{ window_days }} dias</div>
    <h1>{{ title }}</h1>
    <div class="totals">
      <div class="total-chip"><span class="dot critico"></span> Crítico <b>{{ counts.critico }}</b></div>
      <div class="total-chip"><span class="dot alto"></span> Alto impacto <b>{{ counts.alto }}</b></div>
      <div class="total-chip"><span class="dot medio"></span> Médio <b>{{ counts.medio }}</b></div>
      <div class="total-chip"><span class="dot info"></span> Contexto positivo <b>{{ counts.info }}</b></div>
    </div>
  </div>
  <div class="gen-meta">
    gerado em {{ generated_at }}
    {% if demo %}<br><span class="demo-badge">DADOS SIMULADOS · MODO DEMO</span>{% endif %}
  </div>
</header>

<!-- ── Radar de emissores ─────────────────── -->
<section>
  <div class="sec-head">
    <div class="sec-title">Radar de emissores</div>
    <div class="sec-sub">score acumulado na semana · ≥ {{ attention_threshold }} pts = atenção imediata</div>
  </div>
  {% if ranking %}
  {% set max_score = ranking[0].score if ranking[0].score > 0 else 1 %}
  <div class="radar">
    {% for r in ranking %}
    <div class="radar-row{% if r.attention %} attention{% endif %}">
      <div class="rank">{{ '%02d' % loop.index }}</div>
      <div class="radar-company-wrap">
        <div class="radar-company">{{ r.company }} <span class="tier-badge">T{{ r.tier }}</span></div>
        {% if r.attention %}<span class="attn-tag">ATENÇÃO IMEDIATA</span>{% endif %}
      </div>
      <div class="radar-mid">
        <div class="bar-track">
          <div class="bar-fill {{ r.worst_severity }}" style="width: {{ (100.0 * r.score / max_score) | round(1) }}%"></div>
        </div>
        <div class="chips">
          {% for ev in r.events %}
          <span class="chip {{ ev.severity }}">{{ ev.label }}{% if ev.count > 1 %} <span class="x">×{{ ev.count }}</span>{% endif %}</span>
          {% endfor %}
        </div>
      </div>
      <div class="radar-score"><b>{{ r.score }}</b><span>pts · {{ r.n_articles }} not.</span></div>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <div class="empty">Nenhum emissor pontuou na janela atual. Rode o pipeline novamente ou amplie a janela em <code>window_days</code>.</div>
  {% endif %}
</section>

<!-- ── Evolução por emissor (90 dias) ─────── -->
<section>
  <div class="sec-head">
    <div class="sec-title">Evolução por emissor</div>
    <div class="sec-sub">sequência de sinais nos últimos {{ evolution_days }} dias · score com decaimento (meia-vida) — deterioração recente pesa mais</div>
  </div>
  {% if evolution %}
  <div class="evo-summary">
    <span class="evo-count critico">{{ status_counts.critico }} Crítico</span>
    <span class="evo-count alto">{{ status_counts.atencao }} Atenção elevada</span>
    <span class="evo-count medio">{{ status_counts.monitorar }} Monitorar</span>
  </div>
  <div class="evo">
    {% for row in evolution %}
    <div class="evo-row status-{{ row.status }}">
      <div class="evo-left">
        <div class="evo-company">{{ row.company }} <span class="tier-badge">T{{ row.tier }}</span></div>
        <div class="evo-dates">{{ row.first_date }} → {{ row.last_date }}</div>
        <span class="status-badge {{ status_meta[row.status].severity }}">{{ status_meta[row.status].label }}</span>
      </div>
      <div class="evo-mid">
        <div class="evo-track">
          <div class="evo-track-line"></div>
          {% for occ in row.timeline %}
          <a class="evo-dot {{ occ.severity }}" href="{{ occ.url }}" target="_blank" rel="noopener"
             style="left: {{ occ.pos_pct }}%; opacity: {{ occ.opacity }}"
             title="{{ occ.date }} · {{ occ.label }} — {{ occ.title }}"></a>
          {% endfor %}
        </div>
        <div class="chips">
          {% for ev in row.events %}
          <span class="chip {{ ev.severity }}">{{ ev.label }}{% if ev.count > 1 %} <span class="x">×{{ ev.count }}</span>{% endif %}</span>
          {% endfor %}
        </div>
      </div>
      <div class="radar-score">
        <b>{{ row.total_score }}</b><span>pts pond. · {{ row.timeline | length }} sinais</span>
        <svg class="evo-spark {{ row.status }}" width="84" height="26" viewBox="0 0 100 26" preserveAspectRatio="none" aria-hidden="true">
          <polyline points="{{ row.spark_points }}"/>
        </svg>
        <span class="spark-label">trajetória {{ evolution_days }}d</span>
      </div>
    </div>
    {% endfor %}
  </div>
  <div class="evo-legend">
    <span>← há {{ evolution_days }} dias</span>
    <span>cada ponto é um sinal na linha do tempo · passe o mouse para ver a notícia</span>
    <span>hoje →</span>
  </div>
  {% else %}
  <div class="empty">Nenhum sinal registrado na janela de {{ evolution_days }} dias.</div>
  {% endif %}
</section>

<!-- ── Feed de notícias ───────────────────── -->
<section>
  <div class="sec-head">
    <div class="sec-title">Notícias classificadas</div>
    <div class="sec-sub">{{ feed | length }} notícias na janela</div>
  </div>

  <div class="filters">
    <input type="text" id="q" class="search" placeholder="Buscar por empresa, evento ou título…" oninput="applyFilters()">
    <div class="sev-toggle active critico" data-sev="critico" onclick="toggleSev(this)"><span class="dot critico"></span> Crítico</div>
    <div class="sev-toggle active alto" data-sev="alto" onclick="toggleSev(this)"><span class="dot alto"></span> Alto</div>
    <div class="sev-toggle active medio" data-sev="medio" onclick="toggleSev(this)"><span class="dot medio"></span> Médio</div>
    <div class="sev-toggle active info" data-sev="info" onclick="toggleSev(this)"><span class="dot info"></span> Positivo</div>
    <select id="companySel" onchange="applyFilters()">
      <option value="">Todas as empresas</option>
      {% for c in companies %}<option value="{{ c | lower }}">{{ c }}</option>{% endfor %}
    </select>
  </div>

  {% for sev in ['critico', 'alto', 'medio', 'info'] %}
  {% set group = feed | selectattr('severity', 'equalto', sev) | list %}
  <div class="sev-group" data-sev-group="{{ sev }}">
    <div class="sev-group-head">
      <div class="sev-group-title">{{ severity_meta[sev].emoji }} {{ severity_meta[sev].label }}{% if severity_meta[sev].sub %} <span style="color:var(--muted);font-weight:400;font-size:12px">({{ severity_meta[sev].sub }})</span>{% endif %}</div>
      <div class="sev-group-count" data-count>{{ group | length }} notícia{{ 's' if group | length != 1 }}</div>
    </div>
    <div class="cards">
      {% for art in group %}
      <div class="card {{ sev }}" data-sev="{{ sev }}"
           data-search="{{ (art.title ~ ' ' ~ (art.companies | join(' ')) ~ ' ' ~ (art.events | map(attribute='label') | join(' ')) ~ ' ' ~ art.source) | lower }}"
           data-companies="{{ art.companies | join('|') | lower }}">
        <div class="card-top">
          <div class="card-title"><a href="{{ art.url }}" target="_blank" rel="noopener">{{ art.title }}</a></div>
          <div class="card-score {{ sev }}">{{ art.score }}</div>
        </div>
        {% if art.summary %}<div class="card-summary">{{ art.summary }}</div>{% endif %}
        <div class="chips">
          {% for ev in art.events %}<span class="chip {{ ev.severity }}">{{ ev.label }}</span>{% endfor %}
        </div>
        <div class="card-meta">
          <div class="company-tags">
            {% for c in art.companies %}<span class="company-tag">{{ c }}</span>{% endfor %}
          </div>
          <span>{{ art.source }} · {{ art.pub_iso }}</span>
        </div>
      </div>
      {% endfor %}
      {% if not group %}<div class="empty" style="grid-column:1/-1">Sem notícias nesta severidade na janela.</div>{% endif %}
    </div>
  </div>
  {% endfor %}
</section>

<footer>
  <span>{{ title }}</span>
  <span>classificação por taxonomia de eventos · scoring semanal por emissor</span>
</footer>
</div>

<script>
const activeSev = new Set(['critico','alto','medio','info']);
function toggleSev(el){
  const s = el.dataset.sev;
  if(activeSev.has(s)){ activeSev.delete(s); el.classList.remove('active'); }
  else { activeSev.add(s); el.classList.add('active'); }
  applyFilters();
}
function applyFilters(){
  const q = document.getElementById('q').value.trim().toLowerCase();
  const comp = document.getElementById('companySel').value;
  document.querySelectorAll('.sev-group').forEach(group => {
    const sev = group.dataset.sevGroup;
    let visible = 0;
    group.querySelectorAll('.card').forEach(card => {
      const okSev = activeSev.has(sev);
      const okQ = !q || card.dataset.search.includes(q);
      const okC = !comp || card.dataset.companies.split('|').includes(comp);
      const show = okSev && okQ && okC;
      card.style.display = show ? '' : 'none';
      if(show) visible++;
    });
    group.style.display = activeSev.has(sev) ? '' : 'none';
    const counter = group.querySelector('[data-count]');
    if(counter) counter.textContent = visible + (visible === 1 ? ' notícia' : ' notícias');
  });
}
</script>
</body>
</html>
